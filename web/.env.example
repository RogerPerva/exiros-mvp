# Plantilla de entorno del portal web (Vite). Copiar a web/.env.local para dev,
# o definir estas variables al COMPILAR para producción (vite build).
# web/.env.local está gitignoreado; este .env.example SÍ se versiona.

# URL del backend. Si NO se define, la web usa http://localhost:3000 (solo dev).
# ⚠️ EN PRODUCCIÓN hay que compilar con la URL real del backend (EC2/cloudflared),
#    o el portal desplegado intentará pegarle a localhost y fallará:
#    VITE_API_URL=https://tu-url-cloudflared npm run build
VITE_API_URL="http://localhost:3000"

# Periodo de refresco del mapa en ms. Default de producción: 900000 (15 min).
# En dev se suele bajar a 30000 (30 s) para ver cambios rápido.
VITE_POLL_MS="900000"
