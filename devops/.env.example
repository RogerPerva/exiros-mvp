# Renombrar este archivo a .env y completar los valores antes de levantar.

# Base de datos
POSTGRES_USER=exiros
POSTGRES_PASSWORD=password-segura
POSTGRES_DB=exiros

# Secretos del backend
APP_KEY=exiros-app-key-2026
TRIP_TOKEN_SECRET=secreto-largo-aleatorio
JWT_SECRET=secreto-largo-aleatorio
JWT_EXPIRES_IN=12h

# URL pública del portal web (con https://)
WEB_ORIGIN=https://portal.tudominio.com

# Token del túnel de Cloudflare (Zero Trust → Tunnels → tu túnel → Token)
CLOUDFLARE_TOKEN=token-de-cloudflare

# true si cloudflared está delante (siempre true en este setup)
TRUST_PROXY_IP=true
