# Copiar este archivo a infra/.env y completar los valores REALES.
# Este archivo SÍ va en git (es solo plantilla sin secretos).

# Base de datos
POSTGRES_USER=exiros
POSTGRES_PASSWORD=CAMBIAR-PASSWORD-SEGURO
POSTGRES_DB=exiros

# Secretos del backend (APP_KEY debe coincidir con el APK Android)
APP_KEY=CAMBIAR-APP-KEY
TRIP_TOKEN_SECRET=CAMBIAR-TRIP-TOKEN-SECRET
JWT_SECRET=CAMBIAR-JWT-SECRET
JWT_EXPIRES_IN=12h

# CORS: URL pública del portal (la que el navegador ve)
WEB_ORIGIN=https://TU-DOMINIO-PUBLICO

# true si cloudflared/proxy está delante (rate-limit usa IP real del cliente)
TRUST_PROXY_IP=true

# Opcional: URL base de la API para variables VITE_* en el frontend
VITE_API_URL=
