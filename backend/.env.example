# Plantilla de entorno del backend — copiar a backend/.env.
# DATABASE_URL apunta al Postgres de infra/docker-compose.yml (valores por defecto).
DATABASE_URL="postgresql://exiros:exiros_dev@localhost:5432/exiros?schema=public"

# Clave estática del bootstrap móvil (X-App-Key) — ADR-007 (débil por diseño).
APP_KEY="dev-app-key-cambia-en-prod"
# Secreto de servidor para derivar el tripToken por HMAC.
TRIP_TOKEN_SECRET="dev-trip-token-secret-cambia-en-prod"

# Secreto para firmar el JWT del staff web (Fase 6.1) + vigencia del token.
JWT_SECRET="dev-jwt-secret-cambia-en-prod"
JWT_EXPIRES_IN="12h"

# Admin sembrado por `npx prisma db seed` (Fase 6.1) — cambiar en prod.
SEED_ADMIN_EMAIL="admin@exiros.com"
SEED_ADMIN_PASSWORD="admin1234"
SEED_ADMIN_NAME="Admin Exiros"

# === Red / despliegue (opcionales en dev; AJUSTAR en producción / EC2) ===

# Puerto HTTP del backend. Por defecto 3000.
PORT="3000"

# CORS: origen permitido del portal web. En dev se omite (refleja cualquier origen).
# En PRODUCCIÓN poner el dominio exacto del portal, p.ej. "https://portal.exiros.com".
WEB_ORIGIN=""

# === Seguridad / rate-limit ===

# Ventana y tope del rate-limit global (anti-abuso). Por defecto 100 req / 60 s por IP.
THROTTLE_TTL_MS="60000"
THROTTLE_LIMIT="100"

# Rate-limit específico del endpoint de ingesta móvil (/api/mobile/locations),
# aplicado por tripToken (no por IP). Por defecto 60 lotes / 60 s por viaje.
INGEST_THROTTLE_TTL_MS="60000"
INGEST_THROTTLE_LIMIT="60"

# Detrás de un proxy de confianza (cloudflared/Cloudflare en el EC2), el backend ve
# 127.0.0.1 como IP de TODAS las peticiones → el rate-limit por IP se vuelve un cubo
# compartido (inútil). Con TRUST_PROXY_IP=true, el rate-limit usa la IP REAL del cliente
# (cabecera CF-Connecting-IP / X-Forwarded-For).
# ⚠️ Esas cabeceras son falsificables: poner "true" SOLO si Cloudflare/cloudflared está
# de verdad delante (entornos donde las reescribe). En acceso directo dejar vacío/false.
TRUST_PROXY_IP=""
